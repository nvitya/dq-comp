// single integer expression tests

//const GVINT    : int = 99;

var g_int8  : int8  = 127;
var g_int16 : int16 = 32767;
var g_int32 : int32 = 0x7FFFFFFF;
var g_int64 : int64 = (1 << 62);

var g_uint64 : int64 = (1 << 63);

var g_uint8  : uint8  = 255;
var g_uint16 : uint16 = 0xFFFF;

var g_cnt : int = 0;
var g_var : int = 100; //GVINT + 1;

function dq_add(a : int, b : int) -> int:
  result = a + b;
endfunc

function dq_mul(a : int, b : int) -> int:
  result = a * b;
endfunc

function dq_voidfunc(a : int):
  g_cnt += a;
endfunc

function dq_call(a : int) -> int:
  var i : int;
  i = dq_add(3, a);
  //dq_voidfunc(1);
  result = i * a;
endfunc

function dq_testfunc(a : int, b : int) -> int:
  var i : int = 0;
  result = 0;
  while i < b:
    result += i;
    i += 1;
  endwhile
endfunc

function dq_testfunc2(a : int, b : int) -> int
{
  var i : int = 0;
  result = 0;
  while i < b
  {
    result += i;
    i += 1;
  }
}

function dq_ilogiops(a : int, b : int) -> int:
  if a AND 1 << 5 != 0:
    result = b OR a;
  else:
    result = NOT b XOR 1;
  endif
endfunc

function dq_ifcheck(a : int, b : int) -> int:
  if a < b:
    return -1;
  elif a > b:
    return 1;
  else:
    return 0;
  endif
endfunc

[[external]] function printf(fmt : ^cchar, ...) -> int;

function main() -> int:
  printf("dq_add(3,4) = %i\n", dq_add(3, 4));  //?check('dq_add(3,4)', 7)

  printf("dq_ilogiops(33, 5) = %li\n", dq_ilogiops(33, 5));

  //printf("(before dq_voidfunc(): g_cnt = %li\n", g_cnt);
  //dq_voidfunc(5);
  //printf("(after dq_voidfunc(5): g_cnt = %li\n", g_cnt);

  printf("dq_testfunc(1,5) = %li\n", dq_testfunc(1, 5));

  return 0;
endfunc